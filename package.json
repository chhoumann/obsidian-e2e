{
  "name": "obsidian-e2e",
  "version": "0.0.0",
  "description": "Vitest-first end-to-end test utilities for Obsidian plugins.",
  "homepage": "https://github.com/chhoumann/obsidian-e2e#readme",
  "bugs": {
    "url": "https://github.com/chhoumann/obsidian-e2e/issues"
  },
  "license": "MIT",
  "author": "Christian B. B. Houmann",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chhoumann/obsidian-e2e.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./vitest": {
      "types": "./dist/vitest.d.mts",
      "default": "./dist/vitest.mjs"
    },
    "./matchers": {
      "types": "./dist/matchers.d.mts",
      "default": "./dist/matchers.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "check": "vp check",
    "dev": "vp pack --watch",
    "test": "vp test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "vp pack"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@typescript/native-preview": "7.0.0-dev.20260309.1",
    "bumpp": "^10.4.1",
    "typescript": "^5.9.3",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "peerDependencies": {
    "vite-plus": "^0.1.11"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
